              "raw": "{\n  \"id\": \"evt_test_123\",\n  \"type\": \"payment.succeeded\",\n  \"data\": {\n    \"transactionId\": \"txn_123456\",\n    \"amount\": 1000,\n    \"currency\": \"PHP\",\n    \"status\": \"completed\"\n  },\n  \"timestamp\": \"2024-01-01T12:00:00Z\",\n  \"signature\": \"{{webhook_signature}}\"\n}"
