{
  "info": {
    "name": "CPay API Collection",
    "description": "Complete API collection for CPay payment platform integration. Includes all endpoints, authentication, and example requests.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_secret_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://asia-southeast1-applez-dch9v.cloudfunctions.net",
      "type": "string"
    },
    {
      "key": "api_secret_key",
      "value": "sk_test_your_test_key_here",
      "type": "string",
      "description": "Your CPay API secret key (test or live)"
    },
    {
      "key": "user_id",
      "value": "test_user_123",
      "type": "string",
      "description": "Test user ID for API calls"
    },
    {
      "key": "partner_id",
      "value": "test_partner_123",
      "type": "string",
      "description": "Test partner ID for API calls"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "API authentication and security endpoints",
      "item": [
        {
          "name": "Test API Connection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"getWalletBalance\",\n  \"data\": {\n    \"uid\": \"{{user_id}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/cpayDispatcher",
              "host": ["{{base_url}}"],
              "path": ["cpayDispatcher"]
            },
            "description": "Test your API connection by getting a wallet balance"
          },
          "response": []
        }
      ]
    },
