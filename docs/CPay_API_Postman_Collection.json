  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set environment variables based on request",
          "if (pm.request.url.host.includes('test')) {",
          "    pm.environment.set('environment', 'test');",
          "} else {",
          "    pm.environment.set('environment', 'live');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Common test script for all requests",
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('Response has success field', function () {",
          "    const response = pm.response.json();",
          "    pm.expect(response).to.have.property('success');",
          "});",
          "",
          "pm.test('Response time is less than 5000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "// Store response data for use in other requests",
          "if (pm.response.json().success) {",
          "    const response = pm.response.json();",
          "    if (response.data && response.data.id) {",
          "        pm.environment.set('last_transaction_id', response.data.id);",
          "    }",
          "}"
        ]
      }
    }
  ]
} 