rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminUser() {
      return signedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'superadmin'
      );
    }

    function partnerUser(partnerId) {
      return signedIn() &&
        request.auth.token.role == 'partner' &&
        request.auth.token.partnerId == partnerId;
    }

    match /kyc/{uid}/{fileName} {
      allow read: if adminUser() || (signedIn() && request.auth.uid == uid);
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if adminUser() || (signedIn() && request.auth.uid == uid);
    }

    match /kyb/{partnerId}/{fileName} {
      allow read: if adminUser() || partnerUser(partnerId);
      allow create, update: if partnerUser(partnerId);
      allow delete: if adminUser() || partnerUser(partnerId);
    }

    match /reports/{fileName} {
      allow read, write: if adminUser();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
