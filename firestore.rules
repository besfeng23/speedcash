rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuth() && (getRole() == 'admin' || getRole() == 'superadmin');
    }

    function isSuperAdmin() {
      return isAuth() && getRole() == 'superadmin';
    }

    function isPartner() {
      return isAuth() && getRole() == 'partner';
    }

    function getPartnerId() {
      return request.auth.token.partnerId;
    }

    function sameUserImmutableRole(userId) {
      return isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'kycStatus', 'walletStatus', 'limits', 'riskFlags']);
    }

    // User profiles. Users can create/update their own non-privileged profile fields.
    // Admin SDK/Cloud Functions bypass these rules for trusted provisioning and reviews.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        !request.resource.data.keys().hasAny(['role', 'kycStatus', 'walletStatus', 'limits', 'riskFlags']);
      allow update: if sameUserImmutableRole(userId) || isAdmin();
      allow delete: if isSuperAdmin();

      // Wallet balances must never be written directly by clients.
      // Cloud Functions/Admin SDK are the only allowed writers.
      match /wallets/{walletId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;
      }

      match /kai_interactions/{interactionId} {
        allow read, create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // Users can read only transactions they are part of. Creation/status mutation is backend-only.
    match /transactions/{transactionId} {
      allow read: if isAuth() && (
        (resource.data.userIds is list && resource.data.userIds.hasAny([request.auth.uid])) ||
        isAdmin()
      );
      allow create, update, delete: if false;
    }

    // Immutable ledger entries are backend-only, admin-readable.
    match /ledger_entries/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Cashout requests are created and mutated by backend functions only.
    match /cashout_requests/{requestId} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if false;
    }

    // KYC submissions. Users submit their own data; admins review and write status.
    match /kyc_submissions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'reviewedBy', 'reviewedAt', 'rejectionReason']) ||
        isAdmin();
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if isAdmin() || (isPartner() && getPartnerId() == partnerId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isPartner() && getPartnerId() == partnerId);

      match /kyb_documents/{docId} {
        allow read: if isAdmin() || (isPartner() && getPartnerId() == partnerId);
        allow create, update: if isAdmin() || (isPartner() && getPartnerId() == partnerId);
        allow delete: if isAdmin();
      }
    }

    match /platform_config/{configId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /fx_quotes/{quoteId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /webhook_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
