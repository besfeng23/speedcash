    "firebase": "^11.9.1",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.4.0",
    "jsqr": "^1.4.0",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.475.0",
    "next": "^15.4.2",
    "patch-package": "^8.0.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
