{
  "type": "module",
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "genkit:dev": "cd functions && genkit start --tsx src/ai/dev.ts",
    "genkit:watch": "cd functions && genkit start --tsx --watch src/ai/dev.ts",
    "build": "next build",
    "build:export": "next build && next export",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:watch": "jest --watch",
    "build:functions": "cd functions && npm run build",
    "build:all": "npm run build && npm run build:functions",
    "deploy:staging": "firebase deploy --only hosting,functions --project staging",
    "deploy:production": "firebase deploy --only hosting,functions --project production",
    "deploy": "npm run build && firebase deploy --only hosting",
    "lint:fix": "next lint --fix"
  },
  "dependencies": {
