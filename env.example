# Speedcash environment template
# Copy this file to .env.local for local development.
# Never commit real values. Rotate any key that was previously committed.

# Firebase public web config
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace_with_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://replace_with_project-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace_with_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace_with_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace_with_measurement_id

# Environment
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/replace_with_project_id/asia-southeast1/cpayDispatcher
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Project information
PROJECT_NAME=speedcash
PROJECT_NUMBER=replace_with_project_number
PARENT_ORG=replace_with_parent_org
SUPPORT_EMAIL=support@example.com
APP_VERSION=0.1.0

# AI configuration
GEMINI_API_KEY=replace_with_gemini_key
OPENAI_API_KEY=replace_with_openai_key

# Channel aggregator configuration
CHANNEL_AGGREGATOR_MERCHANT_NAME=replace_with_merchant_name
CHANNEL_AGGREGATOR_MERCHANT_NO=replace_with_merchant_number
CHANNEL_AGGREGATOR_SHA256_KEY=replace_with_channel_aggregator_sha256_key
CHANNEL_AGGREGATOR_ENDPOINT=https://replace_with_channel_aggregator_endpoint

# Payment gateway configuration
BANK_API_KEY=replace_with_bank_api_key
PARTNER_API_KEY=replace_with_partner_api_key
PAYMENT_GATEWAY_KEY=replace_with_payment_gateway_key
PAYMENT_GATEWAY_SECRET=replace_with_payment_gateway_secret
INSTAPAY_API_KEY=replace_with_instapay_key
INSTAPAY_SECRET_KEY=replace_with_instapay_secret
INSTAPAY_ENDPOINT=https://replace_with_instapay_endpoint
GCASH_API_KEY=replace_with_gcash_key
GCASH_SECRET_KEY=replace_with_gcash_secret
GCASH_ENDPOINT=https://replace_with_gcash_endpoint
MAYA_API_KEY=replace_with_maya_key
MAYA_SECRET_KEY=replace_with_maya_secret
MAYA_ENDPOINT=https://replace_with_maya_endpoint
KOREAN_BANK_API_KEY=replace_with_korean_bank_key
KOREAN_BANK_SECRET_KEY=replace_with_korean_bank_secret
KOREAN_BANK_ENDPOINT=https://replace_with_korean_bank_endpoint

# eMango / SpeedyPay integrations
EMANGO_MICROSERVICE_URL=http://localhost:5000
EMANGO_SECRET_KEY=replace_with_emango_secret
SPEEDYPAY_SECRET_KEY=replace_with_speedypay_secret
SPEEDYPAY_MERCHANT_SEQ=replace_with_speedypay_merchant_seq

# Email service
MAILCHIMP_API_KEY=replace_with_mailchimp_key
MAILCHIMP_SERVER_PREFIX=replace_with_mailchimp_server_prefix
MAILCHIMP_AUDIENCE_ID=replace_with_mailchimp_audience_id
MAILCHIMP_RETRY_ATTEMPTS=2
MAILCHIMP_CONTACT_STATUS=subscribed
FROM_EMAIL=noreply@example.com
FROM_NAME=Speedcash
REPLY_TO_EMAIL=support@example.com

# Webhook security
INSTAPAY_WEBHOOK_SECRET=replace_with_instapay_webhook_secret
GCASH_WEBHOOK_SECRET=replace_with_gcash_webhook_secret
MAYA_WEBHOOK_SECRET=replace_with_maya_webhook_secret
KOREAN_BANK_WEBHOOK_SECRET=replace_with_korean_bank_webhook_secret
WEBHOOK_SECRET=replace_with_generic_webhook_secret
WEBHOOK_TIMEOUT=30000

# Security configuration
JWT_SECRET=replace_with_jwt_secret
ENCRYPTION_KEY=replace_with_32_byte_encryption_key
ENABLE_RATE_LIMITING=true
ENABLE_2FA=true
ENABLE_WEBHOOK_VERIFICATION=true

# Monitoring and logging
SENTRY_DSN=replace_with_sentry_dsn
LOG_LEVEL=info

# Database
DATABASE_URL=replace_with_database_url

# External services
SMS_API_KEY=replace_with_sms_api_key
EMAIL_API_KEY=replace_with_email_api_key

# Feature flags
ENABLE_KYC=true
ENABLE_AI_ASSISTANT=true
ENABLE_PARTNER_INTEGRATIONS=true
ENABLE_PAYMENT_GATEWAYS=false
ENABLE_KOREAN_MALL_INTEGRATION=false

# Performance
CACHE_TTL=3600
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Settlement configuration
AUTO_SETTLEMENT_ENABLED=false
SETTLEMENT_FREQUENCY=daily
MINIMUM_SETTLEMENT_AMOUNT=100000
